{
  "name": "@tracio/react",
  "version": "0.1.3",
  "description": "Tracio React — Provider + hooks for bot detection & device fingerprinting",
  "license": "MIT",
  "homepage": "https://tracio.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tracio-App/sdk.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Tracio-App/sdk/issues"
  },
  "author": {
    "name": "Tracio",
    "url": "https://tracio.ai"
  },
  "keywords": [
    "tracio",
    "bot-detection",
    "fingerprinting",
    "fraud",
    "react"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ssr": "node --input-type=commonjs -e \"require('./dist/index.cjs')\" && node --input-type=module -e \"import('./dist/index.js')\"",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "attw": "attw --pack .",
    "publint": "publint --strict",
    "size-limit": "size-limit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "peerDependencies": {
    "@tracio/sdk": "workspace:^",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@tracio/sdk": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tracio/internal-config": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^15.11.7",
    "publint": "^0.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "size-limit": "^11.1.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
