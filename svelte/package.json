{
  "name": "@tracio/svelte",
  "version": "0.1.2",
  "description": "Tracio Svelte 5 — store-based API for bot detection & device fingerprinting",
  "license": "MIT",
  "homepage": "https://tracio.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tracio-App/sdk.git",
    "directory": "packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/Tracio-App/sdk/issues"
  },
  "author": {
    "name": "Tracio",
    "url": "https://tracio.ai"
  },
  "keywords": [
    "tracio",
    "bot-detection",
    "fingerprinting",
    "fraud",
    "svelte"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ssr": "node --input-type=commonjs -e \"require('./dist/index.cjs')\" && node --input-type=module -e \"import('./dist/index.js')\"",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "attw": "attw --pack .",
    "publint": "publint --strict",
    "size-limit": "size-limit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "peerDependencies": {
    "@tracio/sdk": "workspace:^",
    "svelte": "^5"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tracio/internal-config": "workspace:*",
    "@tracio/sdk": "workspace:*",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^15.11.7",
    "publint": "^0.3.0",
    "size-limit": "^11.1.6",
    "svelte": "^5.16.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
